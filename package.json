{
  "name": "ai-word-editor",
  "version": "1.0.0",
  "description": "Word AI 编辑助手 - AI-powered document editing assistant",
  "main": "server/index.js",
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "server": "node server/index.js",
    "prestart": "node scripts/prestart.js",
    "setup": "node scripts/setup-dev.js",
    "start": "concurrently -k -n web,proxy -c blue,green \"webpack serve --mode development\" \"node server/index.js\"",
    "build:prod": "npm run build",
    "start:prod": "node server/standalone.js",
    "install:local": "node scripts/install-local.js",
    "check:secrets": "node scripts/check-secrets.js",
    "prepush": "node scripts/check-secrets.js",
    "sideload": "node scripts/sideload.js",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "verify-icons": "node scripts/verify-icons.js",
    "install-certs": "npx office-addin-dev-certs install --machine",
    "fix-icons": "powershell -ExecutionPolicy Bypass -File scripts/fix-word-icons.ps1",
    "postinstall": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.54.0",
    "@fluentui/react-icons": "^2.0.258",
    "core-js": "^3.36.0",
    "cors": "^2.8.5",
    "es6-promise": "^4.2.8",
    "express": "^4.21.0",
    "mammoth": "^1.12.0",
    "mathml2omml": "^0.5.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "regenerator-runtime": "^0.14.1",
    "serverless-http": "^3.2.0",
    "temml": "^0.13.3"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@types/office-js": "^1.0.377",
    "@types/office-runtime": "^1.0.35",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "html-loader": "^5.0.0",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^5.1.0",
    "office-addin-dev-certs": "^1.13.0",
    "office-addin-manifest": "^1.13.0",
    "sharp": "^0.35.3",
    "source-map-loader": "^5.0.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.2",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.2"
  }
}
